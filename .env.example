# Shared config for ClaudeLens. Copy to .env and adjust.

# ── Local development ────────────────────────────────────────────────
PORT=4000
DATABASE_URL=postgres://claudelens:claudelens@localhost:5544/claudelens

# CLI -> server ingest target (developers set this to your internal host)
CLAUDELENS_SERVER=http://localhost:4000
# Optional shared ingest token (leave blank for open localhost dev)
CLAUDELENS_TOKEN=

# ── Production (docker-compose.prod.yml) ─────────────────────────────
# Host port the dashboard + API are exposed on.
CLAUDELENS_PORT=4000
# Postgres password for the bundled db service (change this!).
POSTGRES_PASSWORD=change-me
# REQUIRED in production: any long random string. Only clients that send this
# token may publish sessions. Teammates put the same value in their
# ~/.claude/claudelens.json ("token"). Generate one with:  openssl rand -hex 24
# CLAUDELENS_TOKEN=paste-a-long-random-string-here
