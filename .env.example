# Shared config for ClaudeLens
# Copy to .env and adjust.

# Server
PORT=4000
DATABASE_URL=postgres://claudelens:claudelens@localhost:5544/claudelens

# CLI -> server ingest target (developers set this to your internal host)
CLAUDELENS_SERVER=http://localhost:4000
# Optional shared ingest token (leave blank for open internal network)
CLAUDELENS_TOKEN=
