{
  "name": "@claudelens/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "claudelens": "src/cli.ts"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "setup": "tsx src/cli.ts setup",
    "projects": "tsx src/cli.ts projects",
    "status": "tsx src/cli.ts status",
    "build:plugin": "esbuild src/cli.ts --bundle --platform=node --format=esm --target=node20 --outfile=../plugin/dist/claudelens.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@claudelens/shared": "workspace:*",
    "@clack/prompts": "^0.7.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
